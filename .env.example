# The Gork v2.0 - Environment Variables
# Copy this file to .env and fill in your details

# Dashboard Authentication
GORK_USERNAME=admin
GORK_PASSWORD=admin123
GORK_JWT_SECRET=your_secure_random_jwt_secret_here

# Stake API Configuration
STAKE_API_TOKEN=your_stake_api_token_here

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
