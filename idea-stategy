@app.route('/start', methods=['POST'])
def start():
    data = request.json or {}
    with state_lock:
        cfg = state['config']
        cfg.update({
            'base_bet_pct': float(data.get('base_bet_pct', cfg['base_bet_pct'])),
            'session_tp_pct': float(data.get('session_tp_pct', cfg['session_tp_pct'])),
            'session_sl_pct': float(data.get('session_sl_pct', cfg['session_sl_pct'])),
            'daily_loss_cap_pct': float(data.get('daily_loss_cap_pct', cfg['daily_loss_cap_pct'])),
            'weekly_loss_cap_pct': float(data.get('weekly_loss_cap_pct', cfg['weekly_loss_cap_pct'])),
            'all_time_drawdown_cap_pct': float(data.get('all_time_drawdown_cap_pct', cfg['all_time_drawdown_cap_pct'])),
            'daily_wager_cap_factor': float(data.get('daily_wager_cap_factor', cfg['daily_wager_cap_factor'])),
            'min_bet_floor': float(data.get('min_bet_floor', cfg['min_bet_floor'])),
            'seed_rotate_min': int(data.get('seed_rotate_min', cfg['seed_rotate_min'])),
            'seed_rotate_max': int(data.get('seed_rotate_max', cfg['seed_rotate_max'])),
            'enable_seed_rotation': bool(data.get('enable_seed_rotation', cfg['enable_seed_rotation'])),
            'enable_daily_lock': bool(data.get('enable_daily_lock', cfg['enable_daily_lock'])),
            'enable_weekly_lock': bool(data.get('enable_weekly_lock', cfg['enable_weekly_lock'])),
            'enable_alltime_lock': bool(data.get('enable_alltime_lock', cfg['enable_alltime_lock'])),
        })

        state['daily_start_balance'] = state['balance']['available']
        state['daily_start_time'] = time.time()
        state['weekly_start_balance'] = state['balance']['available']
        state['weekly_start_time'] = time.time()
        state['peak_balance'] = max(state['peak_balance'], state['balance']['available'])
        state['current_bet'] = calculate_gork_bet(state['balance']['available'])
        state['is_running'] = True
        log("The Gork — eternal volume begins")
        save_config()
    return jsonify({'ok': True})

@app.route('/stop', methods=['POST'])
def stop():
    with state_lock:
        state['is_running'] = False
        log("The Gork paused")
    return jsonify({'ok': True})

def log(msg):
    ts = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    with state_lock:
        state['logs'].append(f"[{ts}] {msg}")
        state['logs'][:] = state['logs'][-300:]

if __name__ == '__main__':
    threading.Thread(target=betting_loop, daemon=True).start()
